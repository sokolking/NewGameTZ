# Unity / C# project gitignore

# OS-specific
.DS_Store
Thumbs.db

# Unity generated folders
Library/
Temp/
Obj/
Build/
Builds/
Logs/
MemoryCaptures/
UserSettings/

# Rider / VS / VSCode / JetBrains
.vs/
.vscode/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.unityproj
*.pidb
*.booproj
*.svd

# Packages cache
Packages/com.unity.collab-proxy/

# Burst
.burst/

# Visual Studio Code workspace history
.history/

# Crash / debug reports
sysinfo.txt

# TextMesh Pro
Assets/TextMesh Pro/Resources/*.asset

# Addressables
AddressablesBuildData/*
Assets/AddressableAssetsData/*/*.bin*

# IDE misc
*.DotSettings.user

# .NET server build output
Server/bin/
Server/obj/

# Сервер: отдаваемые клиенту бинарники (dmg и т.д.) — не в git
publish/wwwroot/downloads/*
Server/wwwroot/downloads/*
!Server/wwwroot/downloads/README.txt

# Server: local DB backup exports (large JSON dumps)
Server/wwwroot/backups/

# FBX персонажа ~110MB каждый — лимит GitHub 100MB; держите локально или используйте Git LFS
Assets/Art/Player/*.fbx

Assets/Scripts/Hope.code-workspace
Assets/Scripts/Hope.code-workspace.meta